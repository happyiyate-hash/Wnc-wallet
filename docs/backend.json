
{
  "entities": {
    "Blockchain": {
      "title": "Blockchain",
      "description": "Configuration for supported blockchain networks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "enum": ["evm", "btc", "solana"], "type": "string" },
        "chainId": { "type": "number" },
        "rpcUrl": { "type": "string" }
      }
    },
    "Asset": {
      "title": "Asset",
      "description": "A token or native coin supported by the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "blockchainId": { "type": "string" },
        "symbol": { "type": "string" },
        "decimals": { "type": "number" },
        "contractAddress": { "type": "string" }
      }
    },
    "Wallet": {
      "title": "Wallet",
      "description": "A custodial address derived for a user on a specific chain.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "blockchainId": { "type": "string" },
        "address": { "type": "string" },
        "derivationPath": { "type": "string" }
      }
    },
    "Balance": {
      "title": "Balance",
      "description": "User's internal ledger balance for a specific asset.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "assetId": { "type": "string" },
        "amount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and encrypted vault data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "vault_phrase": { "type": "string", "description": "Encrypted mnemonic" },
        "iv": { "type": "string", "description": "IV for mnemonic" },
        "vault_infura_key": { "type": "string", "description": "Encrypted Infura Key" },
        "infura_iv": { "type": "string", "description": "IV for infura key" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/blockchains/{chainId}": {
      "schema": "Blockchain",
      "description": "Global config for supported chains."
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Global config for supported tokens."
    },
    "/users/{userId}/wallets/{chainId}": {
      "schema": "Wallet",
      "description": "User's custodial addresses per chain."
    },
    "/users/{userId}/balances/{assetId}": {
      "schema": "Balance",
      "description": "User's internal ledger balances."
    }
  }
}
