
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended SmarterSeller identity with multi-chain registry nodes and referral escrow.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "wnc_earnings": { "type": "number" },
        "wnc_referral_escrow": { "type": "number" },
        "account_number": { "type": "string" },
        "vault_phrase": { "type": "string" },
        "iv": { "type": "string" },
        "evm_address": { "type": "string" },
        "xrp_address": { "type": "string" },
        "near_address": { "type": "string" },
        "referral_code": { "type": "string" },
        "onboarding_completed": { "type": "boolean" }
      }
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "A P2P handshake node for requesting multi-chain assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requester_id": { "type": "string" },
        "chain_type": { "type": "string" },
        "token_symbol": { "type": "string" },
        "amount_wnc": { "type": "number" },
        "status": { "enum": ["pending", "paid", "expired", "cancelled"], "type": "string" }
      }
    },
    "Referral": {
      "title": "Referral",
      "description": "Growth event record for the 100 WNC protocol.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "referrer_id": { "type": "string" },
        "referred_id": { "type": "string" },
        "status": { "enum": ["pending", "approved", "credited"], "type": "string" },
        "reward_amount": { "type": "number", "default": 100 }
      }
    },
    "SwapTransaction": {
      "title": "SwapTransaction",
      "description": "A record of an institutional liquidity-provided swap.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "from_chain": { "type": "string" },
        "to_chain": { "type": "string" },
        "from_symbol": { "type": "string" },
        "to_symbol": { "type": "string" },
        "from_amount": { "type": "number" },
        "to_amount_expected": { "type": "number" },
        "admin_fee_usd": { "type": "number" },
        "network_fee_usd": { "type": "number" },
        "status": { "enum": ["pending", "user_sent", "admin_confirmed", "payout_sent", "completed", "failed"], "type": "string" },
        "user_tx_hash": { "type": "string" },
        "admin_tx_hash": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time alert node for ledger events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "from_user_id": { "type": "string" },
        "transaction_id": { "type": "string" },
        "type": { "enum": ["TRANSFER_IN", "TRANSFER_OUT", "REWARD", "REQUEST"], "type": "string" },
        "amount": { "type": "number" },
        "token": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "UserProfile",
      "description": "Institutional identity registry."
    },
    "/swaps/{swapId}": {
      "schema": "SwapTransaction",
      "description": "Historical registry of swap executions."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Real-time user alerts."
    }
  }
}
